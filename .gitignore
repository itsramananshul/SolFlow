# Local maintainer-only reference material — never push.
# Holds notes + .sol fixtures used during development. Not part of
# SolFlow's deliverables.
reference/

# Standard ignores (will grow as MVP scaffolds)
node_modules/
dist/
build/
# Phase C C.8 c103 — `npm run package:local` output. Per-version
# bundles can be large + are inherently rebuildable.
dist-release/
.turbo/
.cache/
coverage/
*.log

# Editor
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example

# Rust / WASM artifacts (Phase 2+)
target/
# Note: `compiler-wasm/pkg/` IS committed (so editor devs don't need
# Rust toolchain). `compiler-wasm/pkg-node/` IS committed (so vitest
# can run real e2e round-trip tests without rebuilding WASM in CI).
# Generic `pkg/` rule still ignores other crates' wasm-pack output.
pkg/
!compiler-wasm/pkg/
!compiler-wasm/pkg/**
pkg-node/
!compiler-wasm/pkg-node/
!compiler-wasm/pkg-node/**
**/*.rs.bk

.vercel
*.db
_qa/
_qa*.mjs
dev-server.log
