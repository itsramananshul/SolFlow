{
  "name": "solflow",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "SolFlow — production visual IDE for the SOL language",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:nocheck": "vite build",
    "build:wasm": "cd compiler-wasm && wasm-pack build --release --target bundler --out-dir pkg",
    "build:wasm:node": "cd compiler-wasm && wasm-pack build --release --target nodejs --out-dir pkg-node",
    "build:wasm:all": "npm run build:wasm && npm run build:wasm:node",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cargo test --workspace",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "check": "npm run typecheck && npm run test && npm run test:rust",
    "regen:fixtures": "bash scripts/regenerate-ast-fixtures.sh"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.0",
    "@codemirror/language": "^6.10.2",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.28.6",
    "@lezer/highlight": "^1.2.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.2",
    "@vue-flow/core": "^1.42.0",
    "@vue-flow/minimap": "^1.5.2",
    "codemirror": "^6.0.1",
    "nanoid": "^5.0.7",
    "pinia": "^2.2.2",
    "vue": "^3.5.6"
  },
  "devDependencies": {
    "@vercel/node": "^3.2.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/ui": "^4.1.7",
    "@vue/tsconfig": "^0.5.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.7",
    "vue-tsc": "^2.1.6"
  }
}
